# Copy to .env in repo root for: docker compose up -d --build

POSTGRES_DB=networkdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# At least 32 characters — generate: openssl rand -base64 48
APP_JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Browser origins allowed to call the API (comma-separated)
APP_CORS_ORIGINS=http://localhost,http://127.0.0.1

WEB_PORT=80
